{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "curve-ai-api-staging",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "curve-ai-staging",
      "database_id": "replace-in-cloudflare-dashboard"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACTS_BUCKET",
      "bucket_name": "curve-ai-staging-artifacts"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ONBOARDING_SESSIONS",
        "class_name": "OnboardingSessionCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["OnboardingSessionCoordinator"]
    }
  ],
  "vars": {
    "PUBLIC_OPS_APP_URL": "https://curve-ai-ops.pages.dev",
    "PUBLIC_STAFF_APP_URL": "https://curve-ai-staff.pages.dev",
    "PUBLIC_ONBOARDING_APP_URL": "https://curve-ai-onboarding.pages.dev",
    "PUBLIC_UPLOAD_APP_URL": "https://curve-ai-upload.pages.dev",
    "PUBLIC_API_URL": "https://curve-ai-api-staging.workers.dev",
    "ALLOWED_ORIGINS": "https://curve-ai-ops.pages.dev,https://curve-ai-staff.pages.dev,https://curve-ai-onboarding.pages.dev,https://curve-ai-upload.pages.dev",
    "REASONING_PROVIDER": "heuristic"
  }
}
