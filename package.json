{
  "name": "curve-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:edge-api": "npm run dev -w @curve-ai/edge-api",
    "dev:web": "npm run dev -w @curve-ai/web",
    "dev:ops-web": "npm run dev -w @curve-ai/ops-web",
    "dev:staff-web": "npm run dev -w @curve-ai/staff-web",
    "dev:upload-web": "npm run dev -w @curve-ai/upload-web",
    "deploy:edge-api": "npm run deploy -w @curve-ai/edge-api",
    "deploy:pages:onboarding": "node scripts/deploy-pages-app.mjs apps/web @curve-ai/web curve-ai-onboarding",
    "deploy:pages:ops": "node scripts/deploy-pages-app.mjs apps/ops-web @curve-ai/ops-web curve-ai-ops",
    "deploy:pages:staff": "node scripts/deploy-pages-app.mjs apps/staff-web @curve-ai/staff-web curve-ai-staff",
    "deploy:pages:upload": "node scripts/deploy-pages-app.mjs apps/upload-web @curve-ai/upload-web curve-ai-upload",
    "deploy:pages:all": "npm run deploy:pages:onboarding && npm run deploy:pages:ops && npm run deploy:pages:staff && npm run deploy:pages:upload",
    "deploy:cloudflare:staging": "npm run deploy:edge-api && npm run deploy:pages:all",
    "test:pages-gate": "node --test shared/review-gate.test.mjs",
    "test:edge-api": "npm run test -w @curve-ai/edge-api",
    "test:web": "npm run test -w @curve-ai/web",
    "test:ops-web": "npm run test -w @curve-ai/ops-web",
    "test:staff-web": "npm run test -w @curve-ai/staff-web",
    "test:upload-web": "npm run test -w @curve-ai/upload-web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
